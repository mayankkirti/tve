{
  "name": "trisha-lv",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "electron-main.cjs",
  "build": {
    "appId": "com.trishafrequencies.lv.app",
    "productName": "Trisha LV",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "guid": "5A4B2C3D-TRISHA-LV-9A0B1C2D3E4F"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs"
    ]
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"vite --port=3000\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/nodemailer": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas": "^3.2.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "firebase": "^12.13.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^172.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mp4-muxer": "^5.2.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "webm-muxer": "^5.1.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  }
}
